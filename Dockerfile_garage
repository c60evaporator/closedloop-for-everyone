# syntax=docker/dockerfile:1

# CUDA and Ubuntu Versions
ARG CUDA_VERSION=12.1.1
ARG UBUNTU_VERSION=22.04
# Base image
FROM nvidia/cuda:${CUDA_VERSION}-cudnn8-devel-ubuntu${UBUNTU_VERSION}

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG http_proxy

ARG TORCH_CUDA=cu121
ARG MINIFORGE_VERSION=24.11.0-1

# マウント先のフォルダを環境変数指定用に保持
ARG CARLA_ROOT="/workspace/CARLA"
ARG CARLA_GARAGE_ROOT="/workspace/carla_garage"
ARG SCENARIO_RUNNER_ROOT="${CARLA_GARAGE_ROOT}/scenario_runner"
ARG LEADERBOARD_ROOT="${CARLA_GARAGE_ROOT}/leaderboard"
ARG TEAM_CODE_ROOT="${CARLA_GARAGE_ROOT}/team_code"

RUN apt-get update && apt-get install --reinstall -y locales && locale-gen en_US.UTF-8 && rm -rf /var/lib/apt/lists/*
ENV LANG en_US.UTF-8
ENV LANGUAGE en_US
ENV LC_ALL en_US.UTF-8
ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    curl \
    vim \
    ca-certificates \
    libjpeg-dev \
    libpng16-16 \
    libtiff5 \
    libpng-dev \
    python3-dev \
    python3-pip \
    python3-setuptools && \
    python3 -m pip install --upgrade pip && \
    rm -rf /var/lib/apt/lists/*

# Install dependencies for CARLA Garage
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 && \
    rm -rf /var/lib/apt/lists/*

# Copy the files into the docker
WORKDIR /workspace
COPY carla_garage/environment.yml ${CARLA_GARAGE_ROOT}/environment.yml
COPY carla_garage/team_code/requirements.txt ${CARLA_GARAGE_ROOT}/team_code/requirements.txt

# Miniforgeで仮想環境構築
RUN curl -fsSL -o /tmp/Miniforge3.sh \
      https://github.com/conda-forge/miniforge/releases/download/${MINIFORGE_VERSION}/Miniforge3-Linux-x86_64.sh \
    && bash /tmp/Miniforge3.sh -b -p /opt/conda \
    && rm /tmp/Miniforge3.sh \
    && /opt/conda/bin/conda clean -ya \
    && /opt/conda/bin/conda env create -f ${CARLA_GARAGE_ROOT}/environment.yml

ENV PATH "/opt/conda/envs/garage_2/bin":"/opt/conda/envs/bin":$PATH

# Install PyTorch and torchvision again to ensure CUDA compatibility
# (requirements.txt installs the default PyPI build, e.g. cu124; pin the
#  +${TORCH_CUDA} local version so pip actually replaces it instead of
#  treating "torch==2.5.0" as already satisfied)
RUN /opt/conda/bin/conda run -n garage_2 \
    pip install \
        torch==2.5.0+${TORCH_CUDA} \
        torchvision==0.20.0+${TORCH_CUDA} \
        torchaudio==2.5.0+${TORCH_CUDA} \
        --index-url https://download.pytorch.org/whl/${TORCH_CUDA}

# 環境変数をARGから読取
ENV CARLA_ROOT=${CARLA_ROOT}
ENV CARLA_GARAGE_ROOT=${CARLA_GARAGE_ROOT}
ENV SCENARIO_RUNNER_ROOT=${SCENARIO_RUNNER_ROOT}
ENV LEADERBOARD_ROOT=${LEADERBOARD_ROOT}
ENV TEAM_CODE_ROOT=${TEAM_CODE_ROOT}

# データセット収集用の環境変数CHALLENGE_TRACK_CODENAMEをMAPに設定（検証用はSENSORS）
ENV DATASET_TRACK_CODENAME=MAP

RUN mkdir -p ${CARLA_GARAGE_ROOT}/results

ENV PYTHONPATH "${CARLA_ROOT}/PythonAPI/carla":"${SCENARIO_RUNNER_ROOT}":"${LEADERBOARD_ROOT}":${PYTHONPATH}

############################################################################################
####                     BEGINNING OF AGENT SPECIFIC COMMANDS                           ####
############################################################################################
# Bench2DriveZoo installation

# Set environment variables for GCC installation
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1
# Install GCC9.4
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc-9 g++-9 \
    wget \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# GPU architecture for mmcv build
ARG TORCH_CUDA_ARCH_LIST=8.9
# Set environment variables for mmcv build
ENV CC=/usr/bin/gcc-9 \
    CXX=/usr/bin/g++-9 \
    CUDA_HOME=/usr/local/cuda \
    CPATH=/usr/local/cuda/include \
    PATH=/usr/local/cuda/bin:${PATH} \
    LD_LIBRARY_PATH=/opt/conda/envs/garage_2/lib:/usr/local/cuda/lib64:${LD_LIBRARY_PATH} \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST} \
    FORCE_CUDA=1 \
    MMCV_WITH_OPS=1
# Install build tools (ninja is already installed by apt)
# (setuptools>=64 is required for editable installs without build isolation;
#  <81 keeps pkg_resources, which old torchmetrics still imports)
RUN /opt/conda/bin/conda run -n garage_2 \
    pip install ninja packaging wheel "setuptools>=64,<81"
# Install Bench2DriveZoo runtime dependencies with Python 3.10 compatible
# versions (Bench2DriveZoo/requirements.txt pins py3.8-era versions such as
# numpy==1.20.0 / numba==0.48.0 that cannot be installed on Python 3.10,
# so the editable install below uses --no-deps instead).
# matplotlib is pinned to 3.5.3 because newer releases drop the
# 'seaborn-whitegrid' style used by Bench2DriveZoo / nuscenes-devkit 1.1.x.
RUN /opt/conda/bin/conda run -n garage_2 \
    pip install \
        addict "yapf==0.40.1" terminaltables prettytable pycocotools \
        lyft_dataset_sdk motmetrics "numba==0.56.4" \
        trimesh similaritymeasures casadi open3d imagecorruptions \
        seaborn ipython pandas descartes \
        "numpy==1.23.5" "matplotlib==3.5.3" Pillow
# numba.errors compatibility shim.
# numba.errors was removed in numba 0.56.0 (moved to numba.core.errors), but
# Bench2DriveZoo/mmcv still imports from the old path.  Instead of modifying
# mmcv source files, inject a thin re-export shim into the installed numba
# package so the import resolves without any change to mmcv code.
RUN /opt/conda/bin/conda run -n garage_2 python -c \
    "import os, numba; \
     p = os.path.join(os.path.dirname(numba.__file__), 'errors.py'); \
     open(p, 'w').write('# compat shim: numba.errors removed in numba 0.56.0\nfrom numba.core.errors import *\n')"
# nuscenes-devkit 1.1.11 (the version matching Bench2DriveZoo's code; 1.2.x
# needs matplotlib>=3.6) is installed with --no-deps because it pins
# Shapely<2.0, which would downgrade the shapely==2.0.4 that carla_garage
# requires. Its actual runtime deps are already installed above.
RUN /opt/conda/bin/conda run -n garage_2 \
    pip install --no-deps "nuscenes-devkit==1.1.11"
# Install Bench2DriveZoo repo
# (--no-build-isolation: setup.py imports torch, which is unavailable
#  in pip's isolated build environment)
WORKDIR /workspace/Bench2DriveZoo
COPY Bench2DriveZoo /workspace/Bench2DriveZoo/
# Delete any pre-compiled .so files that may have been copied from the host.
# Without this, pip install -e . may skip recompilation (treating existing
# binaries as up-to-date) and the container would end up with CPU-only ops.
RUN find /workspace/Bench2DriveZoo -name "*.so" -delete
RUN /opt/conda/bin/conda run -n garage_2 \
    pip install -v -e . --no-build-isolation --no-deps

# Add symbolic links for Bench2DriveZoo
# RUN ln -s /workspace/Bench2DriveZoo ${CARLA_GARAGE_ROOT}/Bench2Drive/

############################################################################################
####                        END OF AGENT SPECIFIC COMMANDS                              ####
############################################################################################

# ── ROS 2 Humble (for the ROS2 topic-publishing data agents) ──────────────────
# ros-base: rclpy, standard interfaces (sensor_msgs/nav_msgs/tf2_msgs/...),
# rosbag2, Fast DDS. vision-msgs: Detection3DArray. sensor-msgs-py: PointCloud2
# helpers (pure Python). rosbag2-storage-mcap: mcap bag output.
# If apt signature errors appear here, the ROS apt key has rotated — switch to
# the ros2-apt-source .deb method from docs.ros.org.
RUN apt-get update && apt-get install -y --no-install-recommends curl gnupg \
    && curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
         -o /usr/share/keyrings/ros-archive-keyring.gpg \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu jammy main" \
         > /etc/apt/sources.list.d/ros2.list \
    && apt-get update && apt-get install -y --no-install-recommends \
        ros-humble-ros-base \
        ros-humble-vision-msgs \
        ros-humble-sensor-msgs-py \
        ros-humble-rosbag2-storage-mcap \
    && rm -rf /var/lib/apt/lists/*

# Bridge /opt/ros/humble into the conda garage_2 interpreter WITHOUT sourcing
# setup.bash: explicit ENV also reaches non-login shells and launch scripts.
# - Only ROS paths go on PYTHONPATH — never /usr/lib/python3/dist-packages,
#   which would shadow conda's numpy==1.23.5 with Ubuntu's 1.21 (ABI break).
# - rclpy's compiled extensions are cp310; conda garage_2 is Python 3.10 too,
#   so the ABI matches. If a "GLIBCXX_x.y.z not found" error ever appears,
#   reorder libstdc++ resolution (conda's copy is newer, normally fine).
# - The ros2 CLI (/opt/ros/humble/bin/ros2) runs under system python3 and is
#   self-contained, so `ros2 topic hz` / `ros2 bag record` work as-is.
# - Fast DDS (default RMW) works with the compose file's network_mode: host;
#   fallback if needed: install ros-humble-rmw-cyclonedds-cpp and set
#   RMW_IMPLEMENTATION=rmw_cyclonedds_cpp.
ENV ROS_DISTRO=humble \
    ROS_VERSION=2 \
    ROS_PYTHON_VERSION=3 \
    ROS_DOMAIN_ID=0 \
    AMENT_PREFIX_PATH=/opt/ros/humble \
    LD_LIBRARY_PATH=/opt/ros/humble/lib:/opt/ros/humble/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH} \
    PYTHONPATH=/opt/ros/humble/lib/python3.10/site-packages:/opt/ros/humble/local/lib/python3.10/dist-packages:${PYTHONPATH} \
    PATH=/opt/ros/humble/bin:${PATH}
# ── End of ROS 2 Humble installation ──────────────────

# non-root user作成
ARG USERNAME=developer
ARG UID=1000
ARG GID=1000
RUN groupadd -g ${GID} ${USERNAME} \
    && useradd -m -u ${UID} -g ${GID} -s /bin/bash ${USERNAME} \
    && chown -R ${UID}:${GID} /workspace
USER ${USERNAME}

# non-root userでcondaを使用できるようにする
RUN echo ". /opt/conda/etc/profile.d/conda.sh" >> ~/.bashrc \
    && echo "conda activate garage_2" >> ~/.bashrc
